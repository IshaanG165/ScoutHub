<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ScoutHub" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/scouthub_green</item>
        <item name="colorPrimaryVariant">@color/scouthub_green</item>
        <item name="colorOnPrimary">@color/scouthub_white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/scouthub_orange</item>
        <item name="colorSecondaryVariant">@color/scouthub_orange</item>
        <item name="colorOnSecondary">@color/scouthub_black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.ScoutHub.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.ScoutHub.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.ScoutHub.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

</resources>
