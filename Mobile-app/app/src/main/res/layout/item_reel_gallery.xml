<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="250dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <!-- Upload Layout -->
    <LinearLayout
        android:id="@+id/upload_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/scouthub_light_grey"
        android:visibility="gone">

        <ImageView
            android:id="@+id/upload_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_add"
            android:tint="@color/scouthub_green" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Upload Reel"
            android:textColor="@color/scouthub_green"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Reel Layout -->
    <RelativeLayout
        android:id="@+id/reel_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <ImageView
            android:id="@+id/thumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/ic_reels" />

        <!-- Overlay with caption and delete button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@drawable/gradient_overlay"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/caption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reel caption"
                android:textColor="@color/scouthub_white"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <ImageView
                android:id="@+id/delete_button"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end"
                android:src="@drawable/ic_delete"
                android:tint="@color/scouthub_white" />

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>
