<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/scouthub_card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Edit Profile"
                android:textColor="@color/scouthub_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/close_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:tint="@color/scouthub_text_secondary"
                android:contentDescription="Close" />

        </LinearLayout>

        <!-- Profile Picture Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/profile_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/default_user_profile" />

                <ImageButton
                    android:id="@+id/change_photo_button"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/circle_background"
                    android:src="@drawable/ic_camera"
                    android:tint="@color/scouthub_white"
                    android:contentDescription="Change photo" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap camera to change photo"
                android:textColor="@color/scouthub_text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Input Fields -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Name -->
            <EditText
                android:id="@+id/name_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Name"
                android:inputType="textPersonName"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:textColor="@color/scouthub_text_primary"
                android:textColorHint="@color/scouthub_text_secondary" />

            <!-- Sport and Position -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/sport_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Sport"
                    android:inputType="text"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:textColor="@color/scouthub_text_primary"
                    android:textColorHint="@color/scouthub_text_secondary" />

                <EditText
                    android:id="@+id/position_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Position"
                    android:inputType="text"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:textColor="@color/scouthub_text_primary"
                    android:textColorHint="@color/scouthub_text_secondary" />

            </LinearLayout>

            <!-- Age, Height, Weight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/age_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Age"
                    android:inputType="number"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:textColor="@color/scouthub_text_primary"
                    android:textColorHint="@color/scouthub_text_secondary" />

                <EditText
                    android:id="@+id/height_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Height (cm)"
                    android:inputType="number"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:textColor="@color/scouthub_text_primary"
                    android:textColorHint="@color/scouthub_text_secondary" />

                <EditText
                    android:id="@+id/weight_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Weight (kg)"
                    android:inputType="number"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:textColor="@color/scouthub_text_primary"
                    android:textColorHint="@color/scouthub_text_secondary" />

            </LinearLayout>

            <!-- Club -->
            <EditText
                android:id="@+id/club_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Club"
                android:inputType="text"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:textColor="@color/scouthub_text_primary"
                android:textColorHint="@color/scouthub_text_secondary" />

            <!-- Location -->
            <EditText
                android:id="@+id/location_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Location"
                android:inputType="text"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:textColor="@color/scouthub_text_primary"
                android:textColorHint="@color/scouthub_text_secondary" />

            <!-- Contact -->
            <EditText
                android:id="@+id/contact_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="Contact"
                android:inputType="phone"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:textColor="@color/scouthub_text_primary"
                android:textColorHint="@color/scouthub_text_secondary" />

        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/cancel_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Cancel"
                android:textColor="@color/scouthub_text_secondary"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <Button
                android:id="@+id/save_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save"
                android:backgroundTint="@color/scouthub_accent_green"
                android:textColor="@color/scouthub_white" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
